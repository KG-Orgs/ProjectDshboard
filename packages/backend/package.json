{
  "name": "@contractor/backend",
  "version": "0.0.1",
  "description": "ContractorAI Backend API (Node.js + Express)",
  "main": "dist/backend/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/backend/src/server.js",
    "db:migrate": "drizzle-kit push:pg --config ./drizzle.config.ts",
    "db:apply-migrations": "bash ./scripts/apply-sql-migrations.sh",
    "db:migrate-to-cloud": "bash ./scripts/migrate-db-to-cloud.sh",
    "db:export-for-teammate": "bash ./scripts/export-db-for-teammate.sh",
    "db:clean-cloud-chunks": "bash ./scripts/clean-cloud-chunk-state.sh",
    "db:restore-chunks-batched": "bash ./scripts/restore-chunks-batched.sh",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "test": "vitest run --config ./vitest.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "retrieval:eval": "tsx ./scripts/retrieval-eval.ts",
    "tier1:ingest": "tsx ./scripts/tier1-ingest.ts",
    "tier2:index": "tsx ./scripts/tier2-index.ts",
    "tier2:stream": "tsx ./scripts/tier2-stream-index.ts",
    "tier2:hydrate": "tsx ./scripts/tier2-hydrate.ts",
    "tier2:overnight": "bash ./scripts/tier2-overnight.sh",
    "tier2:supervisor": "bash ./scripts/tier2-supervisor.sh",
    "tier2:launchd-start": "bash ./scripts/tier2-launchd-start.sh",
    "tier2:launchd-stop": "bash ./scripts/tier2-launchd-stop.sh",
    "test:pdf-serving": "tsx ./scripts/test-pdf-serving.ts",
    "tier2:search": "tsx ./scripts/tier2-search-demo.ts",
    "tier2:ask": "tsx ./scripts/tier2-ask.ts",
    "tier2:ask-batch": "tsx ./scripts/tier2-ask-batch.ts",
    "eval:mlj017": "tsx ./scripts/eval-run.ts",
    "chunk-audit:sample": "tsx ./scripts/tier2-chunk-audit-sample.ts",
    "chunk-audit:smoke": "tsx ./scripts/tier2-chunk-audit-sample.ts -- --smoke",
    "chunk-audit:smoke-run": "tsx ./scripts/tier2-chunk-audit-sample.ts -- --smoke --run-ask",
    "eval:chunk-curated": "tsx ./scripts/eval-run.ts -- --file ./eval/mlj017-chunk-curated-questions.json --report ./eval/mlj017-chunk-curated-report.json",
    "eval:smoke": "tsx ./scripts/eval-run.ts -- --file ./eval/mlj017-smoke-questions.json --report ./eval/mlj017-smoke-eval-report.json",
    "eval:smoke-search": "tsx ./scripts/eval-run.ts -- --file ./eval/mlj017-smoke-questions.json --report ./eval/mlj017-smoke-search-report.json --search-only",
    "eval:realistic": "tsx ./scripts/eval-run.ts -- --file ./eval/mlj017-realistic-questions.json --report ./eval/mlj017-realistic-report.json",
    "eval:realistic-search": "tsx ./scripts/eval-run.ts -- --file ./eval/mlj017-realistic-questions.json --report ./eval/mlj017-realistic-search-report.json --search-only",
    "eval:qwp": "tsx ./scripts/eval-run.ts -- --file ./eval/qwp001-depth-questions.json --report ./eval/qwp001-depth-report.json",
    "link:mlj017-org": "tsx ./scripts/link-mlj017-org.ts",
    "grant:org-access": "tsx ./scripts/grant-org-access.ts",
    "grant:project-access": "tsx ./scripts/grant-project-access.ts",
    "backfill:project-access": "tsx ./scripts/backfill-project-access.ts",
    "backfill:identifiers": "tsx ./scripts/backfill-identifiers.ts"
  },
  "dependencies": {
    "@contractor/ai-actions": "workspace:*",
    "@contractor/shared": "workspace:*",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "express": "^4.18.0",
    "mammoth": "^1.12.0",
    "papaparse": "^5.4.1",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.0",
    "redis": "^4.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.10.0",
    "@types/papaparse": "^5.3.14",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.20.0",
    "supertest": "^7.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
