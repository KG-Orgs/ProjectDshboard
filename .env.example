# ================================
# DATABASE
# ================================
DATABASE_URL=postgresql://user:password@localhost:5432/contractor_ai
REDIS_URL=redis://localhost:6379

# ================================
# MICROSOFT OAUTH2
# ================================
# Register your app at https://portal.azure.com/
# Scopes: openid profile email offline_access Files.Read
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ================================
# BACKEND
# ================================
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# ================================
# FRONTEND (Web)
# ================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=ContractorAI

# ================================
# MOBILE (Expo)
# ================================
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
EXPO_PUBLIC_APP_NAME=ContractorAI

# ================================
# AI / EMBEDDINGS (Phase 1.5)
# ================================
# Gemini is preferred for chat answers. DeepSeek/OpenAI compatibility is retained as fallback.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_CHAT_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
CLAUDE_API_KEY=

# ================================
# VECTOR DATABASE (Phase 2)
# ================================
# Pinecone for vector similarity search
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ================================
# OneDrive / Microsoft Graph
# ================================
# Automatically configured via OAuth2
ONEDRIVE_API_ENDPOINT=https://graph.microsoft.com/v1.0

# ================================
# RETRIEVAL (browser chat / RAG testing)
# ================================
# Match tier2:ask hybrid behavior in the web chat API (off by default in server).
RETRIEVAL_HYBRID_ENABLED=true
# LLM reranker: reorder the top candidates for better top-1 precision.
# Provider "llm" reuses the existing chat LLM (no new vendor). TOP_N is how many
# of the fused candidates get reranked. Rollout obeys CANARY_PROJECT_IDS below.
RETRIEVAL_RERANK_ENABLED=true
RETRIEVAL_RERANK_PROVIDER=llm
RETRIEVAL_RERANK_TOP_N=20
# Optional: limit hybrid/rerank rollout to specific projects (comma-separated UUIDs).
CANARY_PROJECT_IDS=731cfd5d-e647-4551-89e7-0a3cc4915115
# Azure AD tenant — used by pnpm link:mlj017-org to align indexed project with login org.
MICROSOFT_TENANT_ID=
# Parent folder of the tier1/tier2 local corpus (OneDrive root above project folder).
LOCAL_CORPUS_PARENT=/Users/kyle.weixu/Library/CloudStorage/OneDrive-Personal
