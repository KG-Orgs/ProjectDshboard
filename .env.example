# ================================
# DATABASE
# ================================
# Use the same DATABASE_URL on every machine that should share projects/users/index.
# Docker Compose defaults to database name "contractorai" (not contractor_ai).
# For shared cloud Postgres, replace with the team cloud URL (ask Kyle — never commit it).
DATABASE_URL=postgresql://contractor:contractor_dev_password@localhost:5432/contractorai
# One-time local → cloud copy: packages/backend/scripts/migrate-db-to-cloud.sh
# SOURCE_DATABASE_URL=...  # optional; defaults to localhost contractorai above
# TARGET_DATABASE_URL=...  # cloud URL, or set DATABASE_URL in .env to cloud and run pnpm db:migrate-to-cloud
REDIS_URL=redis://localhost:6379

# ================================
# MICROSOFT OAUTH2
# ================================
# Register your app at https://portal.azure.com/
# Scopes: openid profile email offline_access Files.Read
#
# Local redirect URI:
#   http://localhost:3000/auth/callback
# Production / demo redirect URI (must match deployed web URL):
#   https://<your-web-host>/auth/callback
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ================================
# BACKEND
# ================================
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
# Comma-separated browser origins allowed to call the API directly (production demo).
# Example: https://contractorai-web.onrender.com
WEB_ORIGIN=

# ================================
# PLATFORM ACCESS (production)
# ================================
# Comma-separated emails allowed to provision orgs/users and sign in without a prior invite.
# When set, all other users must be added to an org before they can sign in.
# Platform operators can use /admin. Org admins (users.role=admin) manage projects without this.
# Example: kyle.xu4@gmail.com,georgegao1997@gmail.com
PLATFORM_OPERATOR_EMAILS=

# ================================
# FRONTEND (Web)
# ================================
# Browser-visible API URL (used by client-side code if any).
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side proxy target (Docker / split deploy). Leave unset for local pnpm dev.
BACKEND_API_URL=
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=ContractorAI

# ================================
# MOBILE (Expo)
# ================================
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
EXPO_PUBLIC_APP_NAME=ContractorAI

# ================================
# AI / EMBEDDINGS (Phase 1.5)
# ================================
# Gemini is preferred for chat answers. DeepSeek/OpenAI compatibility is retained as fallback.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_CHAT_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
CLAUDE_API_KEY=

# ================================
# VECTOR DATABASE (Phase 2)
# ================================
# Pinecone for vector similarity search
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ================================
# OneDrive / Microsoft Graph
# ================================
# Automatically configured via OAuth2
ONEDRIVE_API_ENDPOINT=https://graph.microsoft.com/v1.0

# ================================
# RETRIEVAL (browser chat / RAG testing)
# ================================
# Match tier2:ask hybrid behavior in the web chat API (off by default in server).
RETRIEVAL_HYBRID_ENABLED=true
# LLM reranker: reorder the top candidates for better top-1 precision.
# Provider "llm" reuses the existing chat LLM (no new vendor). TOP_N is how many
# of the fused candidates get reranked. Rollout obeys CANARY_PROJECT_IDS below.
RETRIEVAL_RERANK_ENABLED=true
RETRIEVAL_RERANK_PROVIDER=llm
RETRIEVAL_RERANK_TOP_N=20
# Optional: limit hybrid/rerank rollout to specific projects (comma-separated UUIDs).
CANARY_PROJECT_IDS=731cfd5d-e647-4551-89e7-0a3cc4915115,145b3dcf-272e-4c45-9e19-953f20f25bb9
# Azure AD tenant — used by pnpm link:mlj017-org to align indexed project with login org.
MICROSOFT_TENANT_ID=
# Parent folder of the tier1/tier2 local corpus (OneDrive root above project folder).
LOCAL_CORPUS_PARENT=/Users/kyle.weixu/Library/CloudStorage/OneDrive-Personal
