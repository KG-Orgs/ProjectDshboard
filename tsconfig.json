{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
      "moduleResolution": "Node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@contractor/shared/*": [
        "packages/shared/src/*"
      ]
    }
  },
  "include": [],
  "references": [
    {
      "path": "./apps/mobile"
    },
    {
      "path": "./apps/web"
    },
    {
      "path": "./packages/shared"
    },
    {
      "path": "./packages/backend"
    }
  ]
}
